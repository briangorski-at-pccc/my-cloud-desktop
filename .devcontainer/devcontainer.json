{
  "name": "Brian's Browser Desktop",
  "dockerComposeFile": "docker-compose.yml",
  "service": "desktop",
  "runServices": [
    "desktop"
  ],
  "workspaceFolder": "/workspaces/my-cloud-desktop",
  "shutdownAction": "stopCompose",
  "overrideCommand": false,
  "forwardPorts": [
    3000
  ],
  "portsAttributes": {
    "3000": {
      "label": "Open Cloud Desktop",
      "onAutoForward": "openBrowserOnce"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "files.autoSave": "afterDelay"
      }
    },
    "codespaces": {
      "openFiles": [
        "START-HERE.md"
      ]
    }
  }
}
